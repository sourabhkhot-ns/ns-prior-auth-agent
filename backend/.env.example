# LLM Configuration — any LiteLLM-supported model
# Examples:
#   openai/gpt-4o-mini
#   openai/gpt-4o
#   anthropic/claude-sonnet-4-5
#   anthropic/claude-haiku-4-5
#   gemini/gemini-1.5-flash
#   groq/llama-3.3-70b-versatile
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.1

# Optional: custom OpenAI-compatible endpoint (MLX, vLLM, Ollama, etc.)
# When set, route via an openai/* model id and set OPENAI_API_KEY=dummy
# LLM_API_BASE=http://localhost:8080/v1

# API Keys — set the one matching your LLM_MODEL
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./prior_auth.db

# App
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8001
