# LLM Configuration — any LiteLLM-supported model
# Examples: anthropic/claude-sonnet-4-20250514, openai/gpt-4o, gemini/gemini-pro
LLM_MODEL=anthropic/claude-sonnet-4-20250514
LLM_TEMPERATURE=0.1

# API Keys (set the one matching your LLM_MODEL)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./prior_auth.db

# App
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
