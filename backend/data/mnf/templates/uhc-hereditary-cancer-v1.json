    { "fieldId": "clinical_indications", "label": "Clinical Indications", "fieldType": "textarea", "required": true, "maxLength": 500, "section": "Clinical Information", "dataSourceHint": "order.clinical_info.indications" },
    { "fieldId": "family_history", "label": "Relevant Family History", "fieldType": "textarea", "required": true, "maxLength": 500, "section": "Clinical Information", "dataSourceHint": "order.clinical_info.family_history", "helpText": "Include relatives, cancer types, and ages at diagnosis" },
