    { "fieldId": "informed_consent", "label": "Informed Consent Obtained", "fieldType": "checkbox", "required": true, "section": "Consent & Attestation" },
    { "fieldId": "clinical_notes_attached", "label": "Clinical Notes Attached", "fieldType": "checkbox", "required": true, "section": "Consent & Attestation" },
    { "fieldId": "prior_testing_results_attached", "label": "Prior Testing Results Attached", "fieldType": "checkbox", "required": false, "section": "Consent & Attestation" },

    { "fieldId": "physician_signature", "label": "Physician Signature", "fieldType": "text", "required": true, "section": "Attestation" },
