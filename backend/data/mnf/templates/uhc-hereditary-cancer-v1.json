    { "fieldId": "medical_necessity_narrative", "label": "Medical Necessity Justification", "fieldType": "textarea", "required": true, "maxLength": 2500, "section": "Medical Necessity", "helpText": "Patient presentation, test rationale, NCCN/ACMG support, clinical utility" },
